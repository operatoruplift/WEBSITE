{
  "$schema": "https://raw.githubusercontent.com/nicumicle/tauri-v2/refs/heads/main/tauri-conf-schema.json",
  "productName": "Operator Uplift",
  "version": "0.1.0",
  "identifier": "com.operatoruplift.desktop",
  "build": {
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Operator Uplift",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co https://api.anthropic.com https://api.openai.com; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: https:"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "../public/logo.svg"
    ],
    "targets": ["dmg", "nsis", "appimage"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
